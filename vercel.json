{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/|assets/|favicon.ico|logo192.png|logo512.png|manifest.json|robots.txt|SRS.pdf).*)",
      "destination": "/index.html"
    }
  ]
}
