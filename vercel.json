{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/client/dist/assets/$1"
    },
    {
      "source": "/((?!api/).*)",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/client/dist/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/client/dist/$1"
    }
  ]
}
